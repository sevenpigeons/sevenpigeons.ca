when:
  - event: ['push']
    branch: ['main']

engine: 'nixery'
dependencies:
  nixpkgs: [zola, coreutils, curl, glibc]

clone:
  skip: false
  depth: 1
  submodules: true

environment:
  SITE_PATH: 'public'
  SITE_NAME: 'main_site'
  WISP_HANDLE: 'sevenpigeons.ca'


steps:
  - name: build
    command: |
      git submodule update --init
      zola --config zola.toml build
  - name: deploy
    command: |
      curl https://sites.wisp.place/nekomimi.pet/wisp-cli-binaries/wisp-cli-x86_64-linux -o wisp-cli 
      chmod +x wisp-cli 
      ./wisp-cli deploy "$WISP_HANDLE" \
        --path "$SITE_PATH" \
        --site "$SITE_NAME" \
        --password "$WISP_APP_PASSWORD"
